{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RuntimeTableDesignPreview",
  "type": "object",
  "required": [
    "schemaVersion",
    "runType",
    "targetKey",
    "status",
    "productionReady",
    "reviewRequired",
    "artifactProposals",
    "blockers",
    "validation"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ServiceCodexRunResult.v1"
    },
    "runType": {
      "const": "TABLE_DESIGN"
    },
    "targetKey": {
      "type": "string"
    },
    "status": {
      "enum": [
        "SUCCEEDED",
        "FAILED",
        "BLOCKED",
        "REVIEW_REQUIRED"
      ]
    },
    "productionReady": {
      "const": false
    },
    "reviewRequired": {
      "const": true
    },
    "artifactProposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifactType",
          "title",
          "contentMarkdown",
          "evidenceRefs",
          "reviewMarkers",
          "previewType",
          "createTableScriptPreview",
          "reviewRequired",
          "blockedFromAutoApply"
        ],
        "properties": {
          "artifactType": {
            "const": "TABLE_DESIGN_PREVIEW"
          },
          "title": {
            "type": "string"
          },
          "contentMarkdown": {
            "type": "string",
            "pattern": "REVIEW_REQUIRED"
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "reviewMarkers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "contains": {
              "const": "REVIEW_REQUIRED"
            }
          },
          "previewType": {
            "const": "TABLE_DESIGN_PREVIEW"
          },
          "createTableScriptPreview": {
            "type": "string",
            "pattern": "CREATE\\s+TABLE"
          },
          "reviewRequired": {
            "const": true
          },
          "blockedFromAutoApply": {
            "const": true
          }
        },
        "additionalProperties": true
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "schemaValid",
        "policyValid",
        "staticValidationPassed"
      ],
      "properties": {
        "schemaValid": {
          "type": "boolean"
        },
        "policyValid": {
          "type": "boolean"
        },
        "staticValidationPassed": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
