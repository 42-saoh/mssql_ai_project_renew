{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceCodexRunResult",
  "type": "object",
  "required": [
    "schemaVersion",
    "runType",
    "targetKey",
    "status",
    "productionReady",
    "reviewRequired",
    "artifactProposals",
    "blockers",
    "validation"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ServiceCodexRunResult.v1"
    },
    "runType": {
      "enum": [
        "SP_ANALYSIS",
        "DEPENDENCY_ANALYSIS",
        "TABLE_DESIGN",
        "DRAFT_GENERATION"
      ]
    },
    "targetKey": {
      "type": "string"
    },
    "status": {
      "enum": [
        "SUCCEEDED",
        "FAILED",
        "BLOCKED",
        "REVIEW_REQUIRED"
      ]
    },
    "productionReady": {
      "const": false
    },
    "reviewRequired": {
      "const": true
    },
    "artifactProposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifactType",
          "title",
          "contentMarkdown",
          "evidenceRefs",
          "reviewMarkers"
        ],
        "properties": {
          "artifactType": {
            "enum": [
              "SP_ANALYSIS_DOC",
              "DEPENDENCY_REPORT",
              "DTO_DRAFT",
              "SERVICE_DRAFT",
              "MAPPER_INTERFACE",
              "MAPPER_XML",
              "TABLE_DESIGN_PREVIEW"
            ]
          },
          "title": {
            "type": "string"
          },
          "contentMarkdown": {
            "type": "string"
          },
          "evidenceRefs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "reviewMarkers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "additionalProperties": true
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "schemaValid",
        "policyValid",
        "staticValidationPassed"
      ],
      "properties": {
        "schemaValid": {
          "type": "boolean"
        },
        "policyValid": {
          "type": "boolean"
        },
        "staticValidationPassed": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
